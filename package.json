{
  "name": "appointment-scheduling-api",
  "version": "1.0.0",
  "description": "Appointment scheduling system with MongoDB",
  "main": "dist/server.js",
  "scripts": {
    "start": "node dist/server.js",
    "start:workerDev": "ts-node src/queue/appointmentWorker.ts",
    "start:worker": "node dist/queue/appointmentWorker.js",
    "dev": "nodemon --exec ts-node src/server.ts",
    "build": "tsc",
    "lint": "eslint . --ext .ts",
    "test": "jest",
    "sendDev:morning": "ts-node src/scripts/morningReminder.ts",
    "sendDev:hourly": "ts-node src/scripts/hourlyReminder.ts",
    "devCompletePastAppointments": "ts-node src/scripts/completePastAppointments.ts",
    "completePastAppointments": "node dist/scripts/completePastAppointments.js",
    "send:morning": "node dist/scripts/morningReminder.js",
    "send:hourly": "node dist/scripts/hourlyReminder.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.812.0",
    "@aws-sdk/s3-request-presigner": "^3.812.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.65.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-fileupload": "^1.5.1",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "libphonenumber-js": "^1.12.34",
    "mongoose": "^9.6.1",
    "nodemailer": "^6.9.7",
    "resend": "^6.9.2",
    "sharp": "^0.34.1",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0",
    "winston": "^3.11.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/express-fileupload": "^1.5.1",
    "@types/jest": "^29.5.11",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/lodash.merge": "^4.6.9",
    "@types/node": "^20.10.4",
    "@types/nodemailer": "^6.4.14",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.6",
    "@typescript-eslint/eslint-plugin": "^6.14.0",
    "@typescript-eslint/parser": "^6.14.0",
    "eslint": "^8.55.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
